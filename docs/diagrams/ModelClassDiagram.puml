@startuml
!include style.puml
skinparam arrowThickness 1.1
skinparam arrowColor MODEL_COLOR
skinparam classBackgroundColor MODEL_COLOR

Package Model as ModelPackage <<Rectangle>>{
Class "<<interface>>\nReadOnlyHomeChef" as ReadOnlyHomeChef
Class "<<interface>>\nReadOnlyUserPrefs" as ReadOnlyUserPrefs
Class "<<interface>>\nModel" as Model
Class HomeChef
Class ModelManager
Class UserPrefs

Class UniqueOrderList
Class Order
Class Address
Class Email
Class Food
Class Customer
Class Phone
Class DietTag
Class CompletionStatus
Class PaymentStatus
Class PaymentInfo
Class Date
Class Price

Class I #FFFFFF
}

Class HiddenOutside #FFFFFF
HiddenOutside ..> Model

HomeChef .up.|> ReadOnlyHomeChef

ModelManager .up.|> Model
Model .right.> ReadOnlyUserPrefs
Model .left.> ReadOnlyHomeChef
ModelManager -left-> "1" HomeChef
ModelManager -right-> "1" UserPrefs
UserPrefs .up.|> ReadOnlyUserPrefs

HomeChef *--> "1" UniqueOrderList
UniqueOrderList --> "~* all" Order
Order *--> Food
Order *--> Customer
Order *--> Phone
Order *--> Email
Order *--> Address
Order *--> Date
Order *--> Price
Order *--> "*" DietTag
Order *--> CompletionStatus
Order *--> PaymentStatus
Order *--> "0..1" PaymentInfo

Order -[hidden]up--> I
UniqueOrderList -[hidden]right-> I

Customer -[hidden]right-> Phone
Phone -[hidden]right-> Address
Address -[hidden]right-> Email

ModelManager --> "~* filtered" Order
@enduml
