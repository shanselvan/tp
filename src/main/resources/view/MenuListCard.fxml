<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox id="menuCardPane" fx:id="menuCardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <VBox HBox.hgrow="ALWAYS" spacing="5">
        <padding>
            <Insets top="8" right="10" bottom="8" left="12"/>
        </padding>
        <!-- Row 1: index + name -->
        <HBox spacing="5" alignment="CENTER_LEFT">
            <Label fx:id="id" styleClass="cell_id_label"/>
            <Label fx:id="name" styleClass="cell_big_label" HBox.hgrow="ALWAYS"/>
        </HBox>
        <!-- Row 2: price left, availability right -->
        <HBox alignment="CENTER_LEFT">
            <Label fx:id="price" styleClass="cell_price_label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="availability" styleClass="cell_status_label"/>
        </HBox>
    </VBox>
</HBox>
