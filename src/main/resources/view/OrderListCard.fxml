<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<HBox id="cardPane" fx:id="cardPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <VBox HBox.hgrow="ALWAYS" spacing="3">
        <padding>
            <Insets top="8" right="12" bottom="8" left="12"/>
        </padding>

        <!-- Row 1: index + food name + quantity + diet tags -->
        <HBox spacing="5" alignment="CENTER_LEFT">
            <Label fx:id="id" styleClass="cell_id_label"/>
            <Label fx:id="food" styleClass="cell_big_label" wrapText="true"
                   HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"/>
            <Label fx:id="quantity" styleClass="cell_small_label"/>
            <FlowPane fx:id="dietTags"/>
        </HBox>

        <!-- Row 2: customer — extra top gap to anchor the food name as a headline -->
        <HBox spacing="5" alignment="CENTER_LEFT">
            <VBox.margin><Insets top="3"/></VBox.margin>
            <ImageView fx:id="customerDisplayIcon" fitHeight="13" fitWidth="13" preserveRatio="true" pickOnBounds="true"/>
            <Label fx:id="customer" styleClass="cell_customer_label"/>
        </HBox>

        <!-- Row 3: phone + date side by side -->
        <HBox spacing="16" alignment="CENTER_LEFT">
            <HBox spacing="5" alignment="CENTER_LEFT">
                <ImageView fx:id="phoneDisplayIcon" fitHeight="13" fitWidth="13" preserveRatio="true" pickOnBounds="true"/>
                <Label fx:id="phone" styleClass="cell_small_label"/>
            </HBox>
            <HBox spacing="5" alignment="CENTER_LEFT">
                <ImageView fx:id="dateDisplayIcon" fitHeight="13" fitWidth="13" preserveRatio="true" pickOnBounds="true"/>
                <Label fx:id="date" styleClass="cell_date_label"/>
            </HBox>
        </HBox>

        <!-- Row 4: address -->
        <HBox spacing="5" alignment="CENTER_LEFT">
            <ImageView fx:id="addressDisplayIcon" fitHeight="13" fitWidth="13" preserveRatio="true" pickOnBounds="true"/>
            <Label fx:id="address" styleClass="cell_small_label"/>
        </HBox>

        <!-- Row 5: email + price pushed right -->
        <HBox alignment="CENTER_LEFT">
            <HBox spacing="5" alignment="CENTER_LEFT">
                <ImageView fx:id="emailDisplayIcon" fitHeight="13" fitWidth="13" preserveRatio="true" pickOnBounds="true"/>
                <Label fx:id="email" styleClass="cell_small_label"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="price" styleClass="cell_price_label"/>
        </HBox>

        <!-- Row 6: payment info + status badges pushed right -->
        <HBox spacing="5" alignment="CENTER_LEFT">
            <Label fx:id="paymentInfo" styleClass="cell_small_label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="completionStatus" styleClass="cell_status_label"/>
            <Label fx:id="paymentStatus" styleClass="cell_status_label"/>
        </HBox>
    </VBox>
</HBox>
